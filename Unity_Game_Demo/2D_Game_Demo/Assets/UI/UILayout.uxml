<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 0" name="ScoreLabel" style="top: 20px; align-self: center; -unity-font-style: bold; font-size: 18px; border-left-color: rgb(243, 228, 228); border-right-color: rgb(243, 228, 228); border-top-color: rgb(243, 228, 228); border-bottom-color: rgb(243, 228, 228); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; height: 32px; width: 171px; -unity-background-scale-mode: scale-to-fit; -unity-text-align: middle-center;"/>
    <ui:Button text="Restart" name="RestartButton" style="position: absolute; align-self: center; font-size: 20px; -unity-font-style: bold; top: 50%;"/>
    <ui:Label text="High Score: 0" data-source="" name="HighScoreLabel" enabled="true" style="position: absolute; align-self: center; -unity-font-style: bold; font-size: 18px; -unity-text-outline-width: 0; background-color: rgb(202, 125, 91); -unity-background-image-tint-color: rgb(238, 190, 190); border-left-color: rgb(250, 242, 242); border-right-color: rgb(250, 242, 242); border-top-color: rgb(250, 242, 242); border-bottom-color: rgb(250, 242, 242); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; -unity-background-scale-mode: scale-to-fit; -unity-slice-type: sliced; -unity-paragraph-spacing: 0; height: 36px; width: 171px; -unity-text-align: middle-center; top: 20%;"/>
    <ui:DropdownField name="ThemeDropdown" label="Theme" index="-6" value="Sunset" picking-mode="Position" data-source-type="$BurstDirectCallInitializer, Unity.2D.Common.Editor" style="position: absolute; top: 208px; right: 165px; width: 162px; height: 72px; -unity-font-style: bold; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px; border-left-width: 2px; border-right-width: 2px; border-top-width: 2px; border-bottom-width: 2px; border-left-color: rgb(243, 228, 228); border-right-color: rgb(243, 228, 228); border-top-color: rgb(243, 228, 228); border-bottom-color: rgb(243, 228, 228); background-color: rgb(69, 137, 193); color: rgb(255, 255, 255); align-items: stretch; flex-direction: row; align-self: center; align-content: auto; justify-content: flex-end; flex-wrap: wrap; -unity-text-align: middle-center; white-space: pre-wrap; text-overflow: ellipsis; -unity-background-scale-mode: stretch-to-fill; background-position-x: center; transform-origin: center; flex-basis: auto; opacity: 1; display: flex; visibility: visible; min-width: 20px; aspect-ratio: 1; margin-top: 1px; margin-left: -1px; margin-bottom: -1px; padding-top: -2px; padding-right: 10px; padding-bottom: -2px; padding-left: 13px; background-size: 100% 100%; font-size: 14px;"/>
</ui:UXML>
